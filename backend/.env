# RustDesk Phase 4 - PostgreSQL + REST API
# Backend Environment Variables

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL=postgresql://rustdesk_app:rustdesk_password@localhost:5432/rustdesk_db
POSTGRES_DB=rustdesk_db
POSTGRES_USER=rustdesk_app
POSTGRES_PASSWORD=rustdesk_password_change_me

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# ============================================================================
# SECURITY
# ============================================================================
SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_EXPIRATION_HOURS=24

# ============================================================================
# CORS
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# ============================================================================
# PASSWORD POLICY
# ============================================================================
PASSWORD_MIN_LENGTH=14
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# ============================================================================
# SESSION & RATE LIMITING
# ============================================================================
SESSION_TIMEOUT_MINUTES=30
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60

# ============================================================================
# HEARTBEAT CONFIGURATION
# ============================================================================
HEARTBEAT_INTERVAL_SECONDS=60
HEARTBEAT_TIMEOUT_SECONDS=120
HEARTBEAT_RETENTION_DAYS=30

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/rustdesk-api.log

# ============================================================================
# RUSTDESK INTEGRATION
# ============================================================================
HBBS_HOST=localhost
HBBS_PORT=21115
HBBR_HOST=localhost
HBBR_PORT=21119

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_MFA=true
FEATURE_AUDIT_LOGGING=true
FEATURE_DEVICE_HEARTBEAT=true
FEATURE_ALERTS=true

# ============================================================================
# KUBERNETES (Optional)
# ============================================================================
# DATABASE_URL=postgresql://rustdesk_app:rustdesk_password@postgres-0.postgres:5432/rustdesk_db
# HBBS_HOST=rustdesk-hbbs
# HBBR_HOST=rustdesk-hbbr
