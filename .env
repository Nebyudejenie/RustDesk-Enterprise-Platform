# RustDesk Server Configuration
# Phase 1 - MVP Docker + Unattended Access Core

# Server Identification
RUSTDESK_RELAY_HOST=192.168.1.40
RUSTDESK_SIGNAL_SERVER=192.168.1.40:21115
RUSTDESK_RELAY_SERVER=192.168.1.40:21117
RUSTDESK_API_SERVER=http://127.0.0.1:8000
CUSTOM_RELAY_HOST=relay.yourdomain.com

# Service Ports
HBBS_PORT_21115=21115
HBBS_PORT_21116=21116
HBBS_PORT_21118=21118
HBBR_PORT_21117=21117
HBBR_PORT_21119=21119

# Unattended Access Configuration
RUSTDESK_PERMANENT_PASSWORD=POS@Enterprise2024!Secure
DISABLE_APPROVAL_PROMPTS=true
DISABLE_PERMISSION_DIALOGS=true
AUTO_ACCEPT_CONNECTIONS=true
DISABLE_LOCK_ON_DISCONNECT=true

# Security
RELAY_SECRET_KEY=your-relay-secret-key-change-this-in-production
API_KEY_DEVICE_REGISTRATION=rustdesk-device-api-key-2024
MAX_RELAY_CONNECTIONS=10000

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_ROTATION_SIZE=100M
LOG_RETENTION_DAYS=30

# Database (for future Phase 4)
POSTGRES_USER=rustdesk
POSTGRES_PASSWORD=RustDesk@Postgres2024!Secure
POSTGRES_DB=rustdesk_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Network Timeouts
CONNECTION_TIMEOUT=30
RELAY_TIMEOUT=300
KEEPALIVE_INTERVAL=60

# Device Configuration
DEVICE_ID_PREFIX=POS-ADDIS
DEFAULT_BRANCH_ID=main
AUTO_RESTART_POLICY=always
HEALTH_CHECK_INTERVAL=30s
